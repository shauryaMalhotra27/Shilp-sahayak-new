{
  "name": "shilp-sahayak-nextjs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev",
    "build": "next build && npx @cloudflare/next-on-pages",
    "start": "next start",
    "test:smoke": "next build --webpack",
    "perf:check": "echo \"Use docs/PHASE6_PERFORMANCE_CHECKLIST.md\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "cf:login": "wrangler login",
    "cf:d1:create": "wrangler d1 create shilp_sahayak_db",
    "cf:d1:migrate:local": "wrangler d1 execute shilp_sahayak_db --local --file=./drizzle/migrations/0000_init.sql",
    "cf:d1:migrate:remote": "wrangler d1 execute shilp_sahayak_db --remote --file=./drizzle/migrations/0000_init.sql",
    "cf:d1:check:local": "wrangler d1 execute shilp_sahayak_db --local --command=\"SELECT name FROM sqlite_master WHERE type='table';\"",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "cf:pages:build": "npx @cloudflare/next-on-pages",
    "cf:pages:deploy": "wrangler pages deploy .vercel/output/static --project-name shilp-sahayak-nextjs",
    "cf:pages:deploy:prod": "wrangler pages deploy .vercel/output/static --project-name shilp-sahayak-nextjs --branch main",
    "pages:build": "npx @cloudflare/next-on-pages",
  "pages:preview": "npx @cloudflare/next-on-pages --preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "framer-motion": "^11.5.4",
    "lucide-react": "0.452.0",
    "next": "15.5.2",
    "react": "^18.3.1",
    "react-animated-cursor": "^2.11.2",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "autoprefixer": "latest",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "drizzle-kit": "^0.31.4",
    "wrangler": "^4.39.0",
    "@cloudflare/next-on-pages": "^1.13.8"
  }
}
